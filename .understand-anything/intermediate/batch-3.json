    {
      "id": "concept:client-side-routing",
      "type": "concept",
      "name": "客户端视图路由",
      "summary": "应用使用基于 useState 的客户端视图路由模式——通过 currentView 字符串状态和 switch/case 条件渲染实现页面切换，不依赖 React Router 等第三方路由库。handleNavigate 函数统一处理视图跳转和详情参数传递。",
      "tags": ["pattern", "routing", "spa"],
      "complexity": "simple"
    },
    {
      "id": "concept:provider-composition",
      "type": "concept",
      "name": "Provider 组合模式",
      "summary": "根组件 App 采用 Provider 嵌套组合模式——LanguageThemeProvider → AuthProvider → AiProvider 三层嵌套，确保内部组件可按需消费任意 Context。此模式遵循 React Context 的标准用法：外层 Provider 的状态在内层组件中均可访问。",
      "tags": ["pattern", "react", "context", "architecture"],
      "complexity": "simple"
    },
    {
      "id": "concept:bearer-token-auth",
      "type": "concept",
      "name": "Bearer Token 认证流程",
      "summary": "应用采用基于 localStorage 的 Bearer Token 认证方案。登录成功后将 { token, user } 对象 JSON 序列化存入 localStorage 的 wiki_auth 键；apiFetch 每次请求自动从 localStorage 读取 token 并注入 Authorization 头；AuthProvider 挂载时通过 getMe API 验证 token 有效性。",
      "tags": ["pattern", "auth", "security"],
      "complexity": "simple"
    },
    {
      "id": "concept:ai-integration",
      "type": "concept",
      "name": "AI 功能集成",
      "summary": "前端通过 AiContext 统一封装三项 AI 能力——语义搜索（/search 端点返回匹配的 Entry 列表）、AI 对话（/ai/chat 端点维护对话历史并返回助手回复）、AI 摘要（/ai/summarize 端点对指定 Entry 生成摘要文本）。所有调用通过 apiFetch 统一走后端代理。",
      "tags": ["pattern", "ai", "integration"],
      "complexity": "simple"
    }
