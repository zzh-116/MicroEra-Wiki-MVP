# Server
PORT=3001
JWT_SECRET=your-random-secret-here

# Ollama (local LLM deployment)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=bge-m3

# Milvus Vector DB (optional — falls back to in-memory store)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=wiki_entries
EMBEDDING_DIM=1024

# Vite (frontend dev server)
VITE_API_BASE_URL=http://localhost:3001

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/microera_wiki

# Data directory
DATA_DIR=./backend/data

# DeepSeek API (online LLM for Vercel demo)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# GEMINI_API_KEY is no longer used — replaced by DeepSeek via Ollama
