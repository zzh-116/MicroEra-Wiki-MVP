# Server
PORT=3001
JWT_SECRET=your-random-secret-here

# Ollama (local LLM deployment)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=bge-m3

# Milvus Vector DB (optional - falls back to in-memory store)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=wiki_entries
EMBEDDING_DIM=1024

# Vite (frontend dev server)
VITE_API_BASE_URL=http://localhost:3001

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/microera_wiki

# Data directory
DATA_DIR=./backend/data

# DeepSeek API (online LLM for Vercel demo)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Feishu Connector
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_WIKI_SPACE_ID=your-wiki-space-id

# Sandbox Data Platform
SANDBOX_BASE_URL=http://your-sandbox-server:6810
SANDBOX_USERNAME=admin
SANDBOX_PASSWORD=123456

# Sandbox MySQL direct connection (preferred over HTTP API)
# Set SANDBOX_DB_ENABLED=true to use DB mode — eliminates N+1 HTTP requests
SANDBOX_DB_ENABLED=false
SANDBOX_DB_HOST=10.36.160.33
SANDBOX_DB_PORT=3306
SANDBOX_DB_NAME=miqroproject
SANDBOX_DB_USER=root
SANDBOX_DB_PASSWORD=

# LLM Provider: ollama or deepseek
LLM_PROVIDER=ollama
